NODE_ENV=development
PORT=
DEV_PORT=3000
PROD_PORT=8080

TMDB_API_BASE_URL=https://api.themoviedb.org/3
TMDB_API_KEY=your_tmdb_api_key
TMDB_API_READ_ACCESS_TOKEN=your_tmdb_read_access_token
